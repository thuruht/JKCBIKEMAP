          "content": {
            "mimeType": "text/html",
            "size": 23293,
            "text": "<!DOCTYPE html>\n<html lang=\"en\" data-theme=\"dark\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>JOJO's KC BIKE MAP</title>\n  <link rel=\"icon\" type=\"image/svg+xml\" href=\"data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🚲</text></svg>\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Work+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"/vendor/css/leaflet.css\" />\n  <link rel=\"stylesheet\" href=\"/styles/main.css\">\n  <script src=\"/vendor/js/gsap.min.js\"></script>\n</head>\n<body>\n  <div class=\"crypt-grid\"></div>\n  <div class=\"crypt-scan\"></div>\n  <a class=\"sr-only\" href=\"#map\">Skip to map</a>\n  <main class=\"app\">\n    <aside class=\"sidebar\">\n      <div class=\"brand\">\n        <div class=\"logo\">\n          <img src=\"/byn3.png\" alt=\"JOJO's KC BIKE MAP logo\" style=\"width: 48px; height: 48px; object-fit: contain; border-radius: var(--radius-md);\">\n          <div>\n            <h1>JOJO's KC BIKE MAP</h1>\n            <p class=\"lede\">Shortcuts, trail alerts, and local secrets — community updated.</p>\n          </div>\n        </div>\n        <div style=\"display: flex; gap: var(--space-1);\">\n          <button class=\"toggle\" data-theme-toggle aria-label=\"Switch theme\">◐</button>\n          <button id=\"helpBtn\" class=\"toggle\" aria-label=\"Show help\">?</button>\n        </div>\n      </div>\n\n      <div class=\"controls-group\">\n        <div style=\"display: flex; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;\">\n          <button id=\"tab-explore\" class=\"jump-btn active\" style=\"flex: 1; text-align: center; border: none; border-radius: 0;\">Explore</button>\n          <button id=\"tab-search\" class=\"jump-btn\" style=\"flex: 1; text-align: center; border: none; border-radius: 0;\">Search</button>\n          <button id=\"tab-admin\" class=\"jump-btn\" style=\"flex: 1; text-align: center; border: none; border-radius: 0;\">Admin</button>\n        </div>\n      </div>\n\n      <div id=\"panel-explore\">\n        <section class=\"panel\">\n          <h2>Layers</h2>\n          <div class=\"field\" style=\"margin-bottom: var(--space-4);\">\n            <div style=\"display: flex; align-items: center; gap: var(--space-2); margin-bottom: 4px;\">\n              <label style=\"font-size: var(--text-xs); font-weight: 600;\">Map Style</label>\n              <label style=\"display: flex; align-items: center; gap: 4px; font-size: 9px; cursor: pointer; opacity: 0.8;\" title=\"Automatically switch basemap when changing theme\">\n                <input type=\"checkbox\" id=\"syncThemeBasemap\" checked> Auto-Sync\n              </label>\n            </div>\n            <div style=\"display: flex; gap: var(--space-2);\">\n              <select id=\"basemapSelect\" class=\"jump-btn\" style=\"flex: 1; background: var(--color-bg); font-weight: 600;\">\n                <option value=\"pioneer\" selected>Pioneer (Default)</option>\n                <optgroup label=\"DARK & NIGHT\">\n                  <option value=\"dark\">Crypt Dark</option>\n                  <option value=\"night\">NASA Night Lights</option>\n                  <option value=\"esri_dark\">ESRI Dark Gray</option>\n                </optgroup>\n                <optgroup label=\"SATELLITE & IMAGERY\">\n                  <option value=\"satellite\">ESRI Satellite</option>\n                  <option value=\"google_sat\">Google Satellite</option>\n                  <option value=\"google_hybrid\">Google Hybrid</option>\n                  <option value=\"usgs_imagery\">USGS Imagery</option>\n                </optgroup>\n                <optgroup label=\"STREET MAPS\">\n                  <option value=\"voyager\">Clean Light (Voyager)</option>\n                  <option value=\"osm\">Standard (OSM)</option>\n                  <option value=\"osm_fr\">OSM France</option>\n                  <option value=\"osm_ch\">OSM Switzerland</option>\n                  <option value=\"public_transport\">Public Transport</option>\n                </optgroup>\n                <optgroup label=\"TOPOGRAPHIC\">\n                  <option value=\"terrain\">OpenTopo (Terrain)</option>\n                  <option value=\"esri_topo\">ESRI Topo</option>\n                  <option value=\"usgs_topo\">USGS Topo</option>\n                </optgroup>\n                <optgroup label=\"OUTDOOR\">\n                  <option value=\"cyclosm\">CyclOSM (Cycling)</option>\n                  <option value=\"outdoors\">Thunderforest Outdoors</option>\n                </optgroup>\n              </select>\n              <button id=\"saveDefaultBasemapBtn\" class=\"jump-btn\" style=\"width: auto; padding: 0 var(--space-3); background: var(--color-primary); color: white; font-size: 10px; font-weight: 700; display: none;\" title=\"Save as default basemap\">SET DEFAULT</button>\n            </div>\n          </div>\n\n          <div class=\"legend-stack\" style=\"margin-bottom: var(--space-4);\">\n            <label class=\"layer-toggle\">\n              <input type=\"checkbox\" id=\"layer-knowledge\" checked>\n              <span class=\"summary-label\">Local Rider Knowledge</span>\n            </label>\n            <label class=\"layer-toggle\">\n              <input type=\"checkbox\" id=\"layer-official\">\n              <span class=\"summary-label\">Official Regional Data (MARC)</span>\n            </label>\n            <label class=\"layer-toggle\">\n              <input type=\"checkbox\" id=\"layer-reports\" checked>\n              <span class=\"summary-label\">Field Reports & Alerts</span>\n            </label>\n            <label class=\"layer-toggle\">\n              <input type=\"checkbox\" id=\"layer-amenities\">\n              <span class=\"summary-label\">Rider Amenities (OSM)</span>\n            </label>\n            \n            <div style=\"height: 1px; background: var(--color-border); margin: 8px 0;\"></div>\n            \n            <label class=\"layer-toggle\">\n              <input type=\"checkbox\" id=\"overlay-railway\">\n              <span class=\"summary-label\">Railway Lines</span>\n            </label>\n            <label class=\"layer-toggle\">\n              <input type=\"checkbox\" id=\"overlay-cycling_routes\" checked>\n              <span class=\"summary-label\">Cycling Routes (Waymarked)</span>\n            </label>\n            <label class=\"layer-toggle\">\n              <input type=\"checkbox\" id=\"overlay-hiking_trails\" checked>\n              <span class=\"summary-label\">Hiking Trails (Waymarked)</span>\n            </label>\n          </div>\n\n          <div id=\"user-auth-section\" class=\"panel\" style=\"margin-bottom: var(--space-4); background: var(--color-surface);\">\n            <div id=\"user-logged-out\">\n              <p style=\"font-size: 11px; color: var(--color-text-muted); margin-bottom: 8px;\">Login to contribute rider knowledge.</p>\n              <div style=\"display: flex; gap: 4px;\">\n                <input type=\"email\" id=\"loginEmailInput\" class=\"jump-btn\" style=\"flex: 1; font-size: 11px; background: var(--color-bg);\" placeholder=\"contributor@kcmo.xyz\">\n                <button id=\"sendMagicLinkBtn\" class=\"jump-btn\" style=\"width: auto; background: var(--color-primary); color: white; font-size: 11px;\">Send Link</button>\n              </div>\n            </div>\n            <div id=\"user-logged-in\" style=\"display: none;\">\n              <div style=\"display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;\">\n                <div>\n                  <p style=\"font-size: 11px; color: var(--color-primary); font-weight: 600;\">✓ Contributor</p>\n                  <p id=\"userEmailDisplay\" style=\"font-size: 10px; color: var(--color-text-muted);\"></p>\n                </div>\n                <button id=\"userLogoutBtn\" class=\"jump-btn\" style=\"width: auto; padding: 2px 6px; font-size: 9px; background: var(--color-surface-offset);\">Logout</button>\n              </div>\n              \n              <div id=\"contributor-stats\" style=\"background: var(--color-bg); padding: 8px; border-radius: 6px; margin-bottom: 8px;\">\n                <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;\">\n                  <span id=\"contributor-level\" style=\"font-size: 10px; font-weight: 700; color: var(--color-primary);\">LEVEL 1 SCOUT</span>\n                  <span id=\"contributor-xp\" style=\"font-size: 9px; opacity: 0.6;\">0 XP</span>\n                </div>\n                <div style=\"height: 4px; background: var(--color-border); border-radius: 2px; overflow: hidden;\">\n                  <div id=\"xp-progress-bar\" style=\"height: 100%; width: 0%; background: var(--color-primary); transition: width 0.3s ease;\"></div>\n                </div>\n              </div>\n\n              <div id=\"user-badges-grid\" style=\"display: flex; gap: 4px; flex-wrap: wrap;\"></div>\n            </div>\n          </div>\n\n          <h2>Navigate</h2>\n          <select id=\"categorySelect\" class=\"jump-btn\" style=\"width: 100%; padding: var(--space-4); font-weight: 700; font-size: var(--text-base); background: var(--color-surface-offset);\">\n            <option value=\"\">All Knowledge Categories</option>\n          </select>\n          <div id=\"featureTiles\" class=\"tiles-grid\"></div>\n        </section>\n      </div>\n\n      <div id=\"panel-search\" style=\"display: none;\">\n        <section class=\"panel\">\n          <h2>Find Location</h2>\n          <p style=\"font-size: 13px; color: var(--color-text-muted); margin-bottom: 12px; font-weight: 500;\">Type a trail name, park, or a street address below.</p>\n          <input type=\"text\" id=\"searchInput\" placeholder=\"e.g. Rock Island or 31st & Main\" class=\"jump-btn\" style=\"padding: var(--space-4); font-size: var(--text-base); font-weight: 600;\">\n          <div id=\"searchResultsList\" class=\"tiles-grid\" style=\"margin-top: var(--space-4); max-height: 50vh; overflow-y: auto;\"></div>\n        </section>\n      </div>\n\n      <div id=\"panel-admin\" style=\"display: none;\">\n        <section class=\"panel\">\n          <h2>Authentication</h2>\n          \n          <div id=\"login-view\">\n            <p class=\"lede\" style=\"margin-bottom: var(--space-4);\">Access rider knowledge management tools.</p>\n            <div class=\"field\">\n              <input type=\"password\" id=\"adminTokenInput\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg); padding: var(--space-3);\" placeholder=\"Enter Admin Token\">\n            </div>\n            <button id=\"submitLoginBtn\" class=\"jump-btn\" style=\"width: 100%; text-align: center; background: var(--color-primary); color: white; margin-top: var(--space-3); font-weight: 600;\">Verify Access</button>\n          </div>\n\n          <div id=\"adminActions\" style=\"display: none;\">\n            <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-4);\">\n              <p style=\"font-size: var(--text-xs); color: var(--color-primary); font-weight: 700; text-transform: uppercase;\">Admin Tools</p>\n              <button id=\"logoutBtn\" class=\"jump-btn\" style=\"width: auto; padding: 2px 8px; font-size: 10px; background: var(--color-surface-offset);\">Logout</button>\n            </div>\n            <div style=\"display: flex; gap: var(--space-2);\">\n              <button id=\"addPointBtn\" class=\"jump-btn\" style=\"flex: 1; text-align: center; background: var(--color-surface);\">+ Point</button>\n              <button id=\"addLineBtn\" class=\"jump-btn\" style=\"flex: 1; text-align: center; background: var(--color-surface);\">+ Line</button>\n            </div>\n            <button id=\"importMarcBtn\" class=\"jump-btn\" style=\"width: 100%; text-align: center; background: var(--color-primary-soft); margin-top: var(--space-2);\">Run MARC Import</button>\n            <button id=\"exportGeoJsonBtn\" class=\"jump-btn\" style=\"width: 100%; text-align: center; background: var(--color-surface); margin-top: var(--space-2);\">Export GeoJSON</button>\n            <button id=\"importGeoJsonBtn\" class=\"jump-btn\" style=\"width: 100%; text-align: center; background: var(--color-surface); margin-top: var(--space-2);\">Import GeoJSON</button>\n            <input type=\"file\" id=\"geoJsonFileInput\" accept=\".geojson,.json\" style=\"display:none;\" />\n          </div>\n        </section>\n      </div>\n    </aside>\n\n    <section class=\"map-wrap\">\n      <div id=\"map\" aria-label=\"Map Container\"></div>\n      \n      <!-- Drawing Controls -->\n      <div id=\"drawing-controls\" style=\"display: none; position: absolute; top: var(--space-4); left: 50%; transform: translateX(-50%); z-index: 1001; background: var(--color-surface); padding: var(--space-3) var(--space-4); border-radius: var(--radius-lg); border: 2px solid var(--color-primary); box-shadow: var(--shadow-md); align-items: center; gap: var(--space-3);\">\n        <p style=\"font-size: 11px; font-weight: 700; color: var(--color-primary); text-transform: uppercase;\">Tracing Route...</p>\n        <button id=\"finishDrawingBtn\" class=\"jump-btn\" style=\"width: auto; padding: 4px 12px; background: var(--color-primary); color: white; border: none; font-weight: 700;\">Finish Line</button>\n      </div>\n\n      <!-- Quick Tools -->\n      <div style=\"position: absolute; bottom: var(--space-6); left: var(--space-6); z-index: 1000; display: flex; flex-direction: column; gap: var(--space-2);\">\n        <button id=\"quickReportBtn\" class=\"toggle\" style=\"background: var(--color-primary); color: white; border: none; box-shadow: var(--shadow-md); width: 48px; height: 48px; font-size: 1.2rem;\" title=\"Report an issue\">⚠</button>\n      </div>\n      <div class=\"floating\">\n        <div class=\"card\" id=\"infoCard\" style=\"display: none;\">\n          <button id=\"closeInfoCard\" style=\"position: absolute; top: 12px; right: 12px; width: 28px; height: 28px; border-radius: 999px; background: var(--color-surface-offset); display: grid; place-items: center; font-size: 16px; color: var(--color-text-faint); border: 1px solid var(--color-border); cursor: pointer; z-index: 1010; opacity: 1;\">×</button>\n          <div id=\"infoCardContent\"></div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <!-- Help Modal -->\n  <div id=\"helpModal\" class=\"modal-overlay\">\n    <div class=\"modal-content\">\n      <h2>How to use this map</h2>\n      <p style=\"margin-top: var(--space-3); color: var(--color-text-muted);\">Think in corridors, not perfect routes. Brush Creek is your east-west spine; Blue River is your north-south spine; parks, bridges, and neighborhoods help you stitch the rest together.</p>\n      <div class=\"note\" style=\"margin-top: var(--space-4); background: var(--color-surface-offset); padding: var(--space-3); border-radius: var(--radius-md);\">\n        <strong>Caution:</strong> Hand-built exploration map, not turn-by-turn navigation. Routes and conditions subject to rain, mud, snow, flooding, stray dogs, automobile traffic, law enforcement and other hazards.\n      </div>\n      <button id=\"closeHelpBtn\" class=\"jump-btn\" style=\"width: 100%; text-align: center; margin-top: var(--space-6); background: var(--color-primary); color: white; padding: var(--space-3);\">Got it</button>\n    </div>\n  </div>\n\n  <!-- Feature Form Modal -->\n  <div id=\"featureModal\" class=\"modal-overlay\">\n    <div class=\"modal-content\">\n      <h2 id=\"modalTitle\">Edit Feature</h2>\n      <form id=\"featureForm\" style=\"display: flex; flex-direction: column; gap: var(--space-4); margin-top: var(--space-4);\">\n        <input type=\"hidden\" id=\"f_id\">\n        <input type=\"hidden\" id=\"f_type\">\n        \n        <div class=\"field\">\n          <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Name</label>\n          <input type=\"text\" id=\"f_name\" required class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n        </div>\n\n        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3);\">\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Category</label>\n            <select id=\"f_category\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\"></select>\n          </div>\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Status</label>\n            <select id=\"f_status\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n              <option value=\"active\">Active</option>\n              <option value=\"caution\">Caution</option>\n              <option value=\"closed\">Closed</option>\n              <option value=\"planned\">Planned</option>\n            </select>\n          </div>\n        </div>\n\n        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3);\">\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Officiality</label>\n            <select id=\"f_officiality\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n              <option value=\"official\">Official</option>\n              <option value=\"unofficial\">Unofficial</option>\n              <option value=\"planned\">Planned</option>\n              <option value=\"social\">Social Path</option>\n            </select>\n          </div>\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Visibility</label>\n            <select id=\"f_visibility\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n              <option value=\"public\">Public</option>\n              <option value=\"sensitive\">Sensitive</option>\n              <option value=\"private\">Private</option>\n            </select>\n          </div>\n        </div>\n\n        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3);\">\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Longevity</label>\n            <select id=\"f_longevity\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n              <option value=\"temporary\">Temporary (48hr fade)</option>\n              <option value=\"permanent\">Permanent / Long-term</option>\n            </select>\n          </div>\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Your Email (for delete/edit)</label>\n            <input type=\"email\" id=\"f_poster_email\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\" placeholder=\"rider@kcmo.xyz\">\n          </div>\n        </div>\n\n        <div class=\"field\">\n          <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Description</label>\n          <textarea id=\"f_description\" rows=\"3\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg); font-family: inherit;\"></textarea>\n        </div>\n\n        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3);\">\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Surface Note</label>\n            <input type=\"text\" id=\"f_surface_note\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n          </div>\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Risk Note (Cops/Dogs/Gaps)</label>\n            <input type=\"text\" id=\"f_risk_note\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n          </div>\n        </div>\n\n        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3);\">\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Weather Sensitivity</label>\n            <select id=\"f_weather\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n              <option value=\"none\">None</option>\n              <option value=\"muddy\">Muddy when wet</option>\n              <option value=\"floods\">Prone to flooding</option>\n              <option value=\"icy\">Icy in winter</option>\n              <option value=\"exposed\">High wind exposure</option>\n            </select>\n          </div>\n          <div class=\"field\">\n            <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Source Confidence</label>\n            <select id=\"f_confidence\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg);\">\n              <option value=\"high\">High (Verified personally)</option>\n              <option value=\"medium\">Medium (Reliable report)</option>\n              <option value=\"low\">Low (Rumor / Satellite only)</option>\n              <option value=\"planned\">Planned (Official PDF)</option>\n            </select>\n          </div>\n        </div>\n\n        <div id=\"sourceLinksSection\" style=\"padding: var(--space-3); background: var(--color-surface-offset); border-radius: var(--radius-md); border: 1px dashed var(--color-border);\">\n          <label style=\"display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; margin-bottom: 8px;\">Source Links</label>\n          <div id=\"sourceLinksList\" style=\"display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px;\"></div>\n          <button type=\"button\" id=\"addSourceLinkBtn\" class=\"jump-btn\" style=\"font-size: 10px; width: auto; background: var(--color-bg);\">+ Add Source URL</button>\n        </div>\n\n        <div class=\"field\">\n          <label style=\"display: block; font-size: var(--text-xs); font-weight: 600; margin-bottom: 4px;\">Geometry (JSON)</label>\n          <div style=\"display: flex; gap: var(--space-2);\">\n            <textarea id=\"f_geometry\" required rows=\"2\" class=\"jump-btn\" style=\"width: 100%; background: var(--color-bg); font-family: monospace; font-size: 10px;\"></textarea>\n            <button type=\"button\" id=\"pickOnMapBtn\" class=\"jump-btn\" style=\"width: auto; white-space: nowrap;\">Pick on Map</button>\n          </div>\n        </div>\n\n        <div style=\"display: flex; gap: var(--space-3); margin-top: var(--space-2);\">\n          <button type=\"button\" id=\"closeModalBtn\" class=\"jump-btn\" style=\"flex: 1; text-align: center;\">Cancel</button>\n          <button type=\"submit\" class=\"jump-btn\" style=\"flex: 1; text-align: center; background: var(--color-primary); color: white;\">Save</button>\n        </div>\n      </form>\n    </div>\n  </div>\n\n  <script src=\"/vendor/js/leaflet.js\"></script>\n  <script type=\"module\" src=\"/js/app.js\"></script>\n<script defer src=\"https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd0