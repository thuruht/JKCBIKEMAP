          "content": {
            "mimeType": "text/css",
            "size": 10246,
            "text": ":root, [data-theme=\"light\"] {\n  --text-xs: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);\n  --text-sm: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);\n  --text-base: clamp(1.125rem, 1.05rem + 0.35vw, 1.25rem);\n  --text-lg: clamp(1.5rem, 1.3rem + 1vw, 2rem);\n  --text-xl: clamp(2rem, 1.8rem + 2vw, 3rem);\n  --space-1: 0.35rem; --space-2: 0.65rem; --space-3: 1rem; --space-4: 1.25rem;\n  --space-5: 1.5rem; --space-6: 2rem; --space-8: 2.5rem; --space-10: 3.5rem; --space-12: 4.5rem;\n  --color-bg:#f4f0e6; --color-surface:#e9e4d7; --color-surface-2:#e2ddd0; --color-surface-offset:#ffffff;\n  --color-border:#d0c8b0; --color-text:#333333; --color-text-muted:#555555; --color-text-faint:#777777;\n  --color-primary:#7a9a8c; --color-primary-soft:rgba(122, 154, 140, 0.2); --color-card:rgba(244, 240, 230, 0.95);\n  --shadow-sm:0 2px 4px #1a19141f; --shadow-md:0 16px 48px #1a19142e;\n  --radius-md:1rem; --radius-lg:1.5rem; --radius-full:999px;\n  --font-display:'Instrument Serif', Georgia, serif; --font-body:'Work Sans', Arial, sans-serif;\n  --sidebar-width: 380px;\n}\n[data-theme=\"dark\"] {\n  --color-bg:#0d0c0bff; --color-surface:#141311ff; --color-surface-2:#1a1917ff; --color-surface-offset:#262422ff;\n  --color-border:#4d4a44ff; --color-text:#f2f0e6ff; --color-text-muted:#d1cec1ff; --color-text-faint:#b0aca2ff;\n  --color-primary:#4f98a3ff; --color-primary-soft:#4f98a33d; --color-card:#141311e6;\n  --shadow-sm:0 2px 4px #00000066; --shadow-md:0 16px 48px #00000080;\n}\n\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\nhtml, body { height: 100%; overflow: hidden; }\nbody{font-family:var(--font-body);font-size:var(--text-base);line-height:1.6;color:var(--color-text);background:var(--color-bg)}\na{color:inherit} button{font:inherit;cursor:pointer;background:none;border:none}\n:focus-visible{outline:2px solid var(--color-primary);outline-offset:3px}\n.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}\n\n.app{display:flex;height: 100dvh; width: 100vw; position: relative; z-index: 2;}\n\n.crypt-grid {\n  position: fixed;\n  inset: 0;\n  pointer-events: none;\n  z-index: 1;\n  background-image: \n    linear-gradient(var(--color-border) 1px, transparent 1px),\n    linear-gradient(90deg, var(--color-border) 1px, transparent 1px);\n  background-size: 40px 40px;\n  background-position: center center;\n  opacity: 0.15;\n}\n\n[data-theme=\"dark\"] .crypt-grid {\n  opacity: 0.08;\n  background-image: \n    linear-gradient(rgba(79, 152, 163, 0.2) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(79, 152, 163, 0.2) 1px, transparent 1px);\n}\n\n.crypt-scan {\n  position: fixed;\n  inset: 0;\n  width: 100%;\n  height: 2px;\n  background: linear-gradient(90deg, transparent, var(--color-primary), transparent);\n  opacity: 0.3;\n  z-index: 1;\n  pointer-events: none;\n}\n\n.sidebar{\n  width: var(--sidebar-width);\n  height: 100%;\n  background: linear-gradient(180deg, var(--color-surface), var(--color-surface-2));\n  border-right: 1px solid var(--color-border);\n  padding: var(--space-6);\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-5);\n  overflow-y: auto;\n  flex-shrink: 0;\n  z-index: 10;\n}\n\n.brand{display:flex;align-items:flex-start;justify-content:space-between;gap:var(--space-2)}\n.logo{display:flex;gap:var(--space-3);align-items:flex-start}\n.logo svg{width:32px;height:32px;color:var(--color-primary);flex:none}\nh1{font-family:var(--font-display);font-size:var(--text-xl);line-height:1.05;letter-spacing:-0.01em;font-weight:400}\n.lede{font-size:var(--text-sm);color:var(--color-text-muted);max-width:32ch;margin-top:var(--space-2);line-height:1.4}\n\n.controls-group { display: flex; flex-direction: column; gap: var(--space-4); }\n\n.toggle{min-width:44px;min-height:44px;border:1px solid var(--color-border);border-radius:var(--radius-full);background:var(--color-surface-offset);display:grid;place-items:center;font-size: 1.1rem;transition: transform 0.2s ease;}\n.toggle:active{transform: scale(0.92);}\n\n.panel{background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-6);box-shadow:var(--shadow-md)}\n.panel h2{font-size:var(--text-sm);margin-bottom:var(--space-4);text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; color: var(--color-primary);}\n\n.legend-stack{display:grid;gap:var(--space-3)}\n\n.tiles-grid {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  margin-top: var(--space-4);\n}\n\n.tile-btn {\n  width: 100%;\n  text-align: left;\n  padding: var(--space-3) var(--space-4);\n  font-size: var(--text-sm);\n  font-weight: 600;\n  line-height: 1.3;\n  border-radius: var(--radius-md);\n  border: 1px solid var(--color-border);\n  background: var(--color-surface);\n  color: var(--color-text);\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  cursor: pointer;\n  transition: all 0.2s ease;\n  overflow: hidden;\n}\n\n.tile-btn:hover {\n  background: var(--color-primary-soft);\n  border-color: var(--color-primary);\n  transform: translateX(4px);\n}\n\n.tile-btn.active {\n  background: var(--color-primary);\n  color: rgb(255, 196, 196);\n  border-color: var(--color-primary);\n  box-shadow: var(--shadow-sm);\n}\n\n.tile-btn small {\n  font-size: 11px;\n  font-weight: 700;\n  color: var(--color-primary);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  opacity: 1 !important;\n}\n\n.tile-btn:hover small {\n  color: rgb(255, 196, 196);\n}\n\n.search-result-item {\n  padding: var(--space-3) var(--space-4);\n  border-radius: var(--radius-md);\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  cursor: pointer;\n  transition: all 0.2s ease;\n  font-size: var(--text-sm);\n  font-weight: 500;\n}\n\n.search-result-item:hover {\n  background: var(--color-primary-soft);\n  border-color: var(--color-primary);\n}\ndetails.group{border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);overflow:hidden}\ndetails.group[open]{background:var(--color-primary-soft)}\nsummary{list-style:none;display:flex;align-items:center;justify-content:space-between;gap:var(--space-3);padding:.7rem .8rem;cursor:pointer}\nsummary::-webkit-details-marker{display:none}\n.summary-left{display:flex;align-items:center;gap:var(--space-3)}\n.swatch{width:10px;height:10px;border-radius:999px;flex:none}\n.summary-label{font-size:var(--text-xs);font-weight:600}\n.summary-copy{display: none;} /* Hide copy in sidebar to save space */\n.chev{font-size:var(--text-xs);color:var(--color-text-faint)}\n.group-body{padding:0 .5rem .5rem .5rem;display:grid;gap:var(--space-1)}\n.jump-btn{width:100%;text-align:left;padding:.5rem .6rem;border-radius:var(--radius-md);border:1px solid var(--color-border);background:var(--color-surface-2);color:var(--color-text);font-size:var(--text-xs)}\n.jump-btn:hover,.jump-btn.active{background:color-mix(in srgb, var(--color-primary) 10%, var(--color-surface-2));border-color:color-mix(in srgb, var(--color-primary) 35%, var(--color-border))}\n\n.layer-toggle {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n  padding: var(--space-1) var(--space-2);\n  border-radius: var(--radius-md);\n  cursor: pointer;\n  transition: background 0.2s ease;\n}\n\n.layer-toggle:hover {\n  background: var(--color-surface-offset);\n}\n\n.layer-toggle input {\n  width: 16px;\n  height: 16px;\n  accent-color: var(--color-primary);\n}\n\n.map-wrap{flex-grow: 1; position:relative; height: 100%;}\n#map{height:100%; width:100%}\n\n.floating{position:absolute; top:var(--space-8); right:var(--space-8); z-index: 1000; pointer-events:none}\n.card{pointer-events:auto; width:400px; background:var(--color-card); backdrop-filter:blur(12px); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:var(--space-6); box-shadow:var(--shadow-md); position: relative; max-height: 85vh; overflow-y: auto;}\n.card h3{font-family:var(--font-display);font-size:var(--text-lg);margin-bottom:var(--space-2);line-height:1.1;color:var(--color-text)}\n.card p{font-size:var(--text-sm);color:var(--color-text-muted);line-height:1.5}\n.note{font-size:var(--text-xs);color:var(--color-text);margin-top:var(--space-4);padding: var(--space-3); background: var(--color-surface-offset); border-radius: var(--radius-md); border-left: 4px solid var(--color-primary);}\n.card small{font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-primary);}\n\n.modal-overlay {\n  display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999; place-items: center; padding: var(--space-4);\n}\n.modal-content {\n  width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto; background: var(--color-surface); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-md);\n}\n\n.custom-marker {\n  transition: transform 0.2s ease;\n}\n.custom-marker:hover {\n  transform: scale(1.25);\n  z-index: 1001 !important;\n}\n\n.leaflet-popup-content-wrapper,.leaflet-popup-tip{background:var(--color-surface);color:var(--color-text)}\n\n@media (max-width: 768px){\n  .app{flex-direction: column-reverse;}\n  .sidebar{\n    width: 100%; \n    height: 50%; \n    border-right: none; \n    border-top: 2px solid var(--color-border); \n    padding: var(--space-4);\n    position: relative;\n  }\n  \n  /* Sticky header for tabs on mobile */\n  .controls-group {\n    position: sticky;\n    top: -1px;\n    background: var(--color-surface);\n    padding-bottom: var(--space-2);\n    z-index: 20;\n    margin: calc(var(--space-4) * -1) calc(var(--space-4) * -1) var(--space-2);\n    padding: var(--space-4);\n    border-bottom: 1px solid var(--color-border);\n  }\n\n  .map-wrap{height: 50%; flex: none;}\n  \n  /* Scroll indicators */\n  .sidebar::after {\n    content: '';\n    position: sticky;\n    bottom: -1px;\n    left: 0;\n    width: 100%;\n    height: 32px;\n    background: linear-gradient(to top, var(--color-surface), transparent);\n    pointer-events: none;\n    display: block;\n    margin-top: -32px;\n  }\n\n  .floating{\n    left:0; right:0; top: auto; bottom: 0; \n    z-index: 1000;\n  }\n  .card { \n    width: 100%; max-width: none; \n    max-height: 48vh; \n    padding: var(--space-5); \n    border-radius: var(--radius-lg) var(--radius-lg) 0 0;\n    border-bottom: none;\n    box-shadow: 0 -8px 32px rgba(0,0,0,0.15);\n  }\n}\n"
